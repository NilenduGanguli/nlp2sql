# Oracle Connection
ORACLE_DSN=localhost:1521/XEPDB1
ORACLE_USER=knowledgeql_reader
ORACLE_PASSWORD=changeme
# Comma-separated list of Oracle schemas to introspect (empty = all accessible)
ORACLE_TARGET_SCHEMAS=KYC_SCHEMA

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# LLM Provider (used by agent layer — not knowledge graph)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...

# Graph Construction Tuning
ORACLE_SAMPLE_ROWS=10
MAX_JOIN_PATH_HOPS=4
SIMILARITY_LEVENSHTEIN_MAX=2
GRAPH_REFRESH_CRON=0 2 * * *

# Safety Limits
MAX_RESULT_ROWS=10000
QUERY_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
