# =============================================================================
# KnowledgeQL — environment configuration
# Copy to .env and fill in your values.
# =============================================================================

# ── Oracle Connection ─────────────────────────────────────────────────────────
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_USER=kyc
ORACLE_PASSWORD=KycPassword1
# Comma-separated list of schemas to introspect
ORACLE_TARGET_SCHEMAS=KYC
# Set to false if the DB user has DBA/SELECT ANY DICTIONARY privilege
ORACLE_USE_DBA_VIEWS=false

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...          # or set OPENAI_API_KEY / ANTHROPIC_API_KEY

# Anthropic alternative:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── Query Execution ───────────────────────────────────────────────────────────
MAX_RESULT_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
DEMO_MODE=false

# ── Graph Construction Tuning ─────────────────────────────────────────────────
MAX_JOIN_PATH_HOPS=4

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
