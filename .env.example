# =============================================================================
# KnowledgeQL — environment configuration
# Copy to .env and fill in your values.
# =============================================================================

# ── Oracle Connection ─────────────────────────────────────────────────────────
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_USER=kyc
ORACLE_PASSWORD=KycPassword1
# Comma-separated list of schemas to introspect
ORACLE_TARGET_SCHEMAS=KYC
# Set to false if the DB user has DBA/SELECT ANY DICTIONARY privilege
ORACLE_USE_DBA_VIEWS=false

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: openai | anthropic | vertex
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...          # or set OPENAI_API_KEY / ANTHROPIC_API_KEY

# Anthropic alternative:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Google Vertex AI alternative (no API key — uses Application Default Credentials):
# LLM_PROVIDER=vertex
# LLM_MODEL=gemini-1.5-pro
# VERTEX_PROJECT=my-gcp-project-id
# VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Query Execution ───────────────────────────────────────────────────────────
MAX_RESULT_ROWS=10000
QUERY_TIMEOUT_SECONDS=30

# ── Graph Cache ───────────────────────────────────────────────────────────────
# Bump GRAPH_CACHE_VERSION to force a full rebuild of the knowledge graph
# (including LLM enhancement) without deleting the cache file.
# A different version string → a different cache filename → automatic cache miss.
GRAPH_CACHE_VERSION=1
# Cache directory (default: /data/graph_cache in Docker, ~/.cache/knowledgeql locally)
# GRAPH_CACHE_PATH=/data/graph_cache
# Max cache age in hours before automatic rebuild (0 = no TTL)
GRAPH_CACHE_TTL_HOURS=0

# ── Graph Construction Tuning ─────────────────────────────────────────────────
MAX_JOIN_PATH_HOPS=4

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
